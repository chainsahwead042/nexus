{
  "name": "nexus-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx server/index.ts",
    "dev:ui": "vite",
    "build": "vite build && cp -r server dist/server 2>/dev/null || true",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.4.0",
    "imap-simple": "^5.1.0",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.7.2",
    "motion": "^12.23.24",
    "nodemailer": "^6.10.1",
    "node-telegram-bot-api": "^0.66.0",
    "octokit": "^5.0.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/imap-simple": "^4.2.4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.14.0",
    "@types/node-telegram-bot-api": "^0.64.8",
    "@types/nodemailer": "^6.4.17",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
